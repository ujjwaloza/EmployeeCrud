@model List<EmployeesCrud.Models.Employee>
@{
    var name = Context.Request.Query["name"].ToString();
    var year = Context.Request.Query["year"].ToString();

    bool isSearchActive = !string.IsNullOrEmpty(name)
                          || !string.IsNullOrEmpty(year);
}
@if (TempData["NoDataMessage"] != null)
{
    <script>
        alert('@TempData["NoDataMessage"]');
    </script>
}


<h2>Employees</h2>

<div class="index-container">
   
    <div class="button-container">
        @* @if (noDataFound)
        {
            <script>
                alert("No records found.");

                window.location.href = '@Url.Action("Index", "Employee")';
            </script>
        } *@
       
        <a asp-action="Create" class="btn btn-success opacity-100 text-dark text-opacity-100">Add</a>
      
        @if (isSearchActive)
        {
            <a asp-action="Index" class="btn btn-secondary">
                Clear
            </a>
        }
        <button type="button" class="search" onclick="openSearchModal()">
            Search
        </button>
      
        <button type="button" id="editBtn" class="btn"
                onclick="openEditModal()" disabled>
            Edit
        </button>

        <button id="deleteBtn" type="button" class="btn " disabled>
            Delete
        </button>
    </div>
   
    <div class="table-container">
        <table class="table table-bordered table-hover table-striped align-middle mt-3" data-toggle="table" data-pagination="true" data-page-size="5" data-page-list="[5]" data-sortable="true" >
            <thead class="table-primary" >
                <tr>
                    <th class="col-select" data-sortable="false">
                        <input type="checkbox" id="selectAll"/>
                    </th>
                    <th class="col-id">
                        <a asp-action="Index"
                           asp-route-sortColumn="Id"
                           asp-route-sortOrder="@(ViewBag.SortOrder == "asc" ? "desc" : "asc")">
                            Id
                        </a>
                    </th>
                    <th class="col-name">
                        <a asp-action="Index"
                           asp-route-sortColumn="FirstName"
                           asp-route-sortOrder="@(ViewBag.SortOrder == "asc" ? "desc" : "asc")">
                            Name
                        </a>
                    </th>
                    <th class="col-gender">
                        <a asp-action="Index"
                           asp-route-sortColumn="Gender"
                           asp-route-sortOrder="@(ViewBag.SortOrder == "asc" ? "desc" : "asc")">
                            Gender
                        </a>
                    </th>
                    <th class="col-dob" >
                        <a asp-action="Index"
                           asp-route-sortColumn="DateOfBirth"
                           asp-route-sortOrder="@(ViewBag.SortOrder == "asc" ? "desc" : "asc")">
                            Date Of Birth
                        </a>
                    </th>
                </tr>
            </thead>

            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>
                            <input type="checkbox"
                                   class="employee-checkbox"
                                   value="@e.Id" />
                        </td>
                        <td>@e.Id</td>
                        <td>@e.FirstName @e.LastName</td>
                        <td>@e.Gender</td>
                        <td>@e.DateOfBirth.ToShortDateString()</td>
                    </tr>
                }
            </tbody>

        </table>
       
    </div>
</div>
