<div id="searchModal" class="modal" >
    <div class="modal-content">

        <span class="close-btn" onclick="closeSearchModal()">&times;</span>

        <h3>Search Employees</h3>

        <div class="search-options">
            <button type="button" class="btn btn-secondary"
                    onclick="showNameSearch()" >
                Search by Name
            </button>

            <button type="button" class="btn btn-secondary"
                    onclick="showYearSearch()" >
                Search by Year
            </button>
        </div>

        <br />

        <form id="nameSearchForm"
              method="get"
              asp-action="Search"
              style="display:none;">

            <input type="text"
                   name="name"
                   placeholder="Enter name..."
                   class="form-control" autocomplete="off" />

            <br />
            <button type="submit" class="btn btn-primary">
                Search
            </button>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-danger">
                        No records found
                    </td>
                </tr>
            }
        </form>

        <form id="yearSearchForm"
              method="get"
              asp-action="Search"
              style="display:none;">

            <input type="number"
                   name="year"
                   placeholder="Enter year (e.g. 2026)"
                   class="form-control" autocomplete="off" />

            <br />
            <button type="submit" class="btn btn-primary">
                Search
            </button>
        </form>

    </div>
</div>

<div id="noDataModal" class="modal">
    <div class="modal-content">
        <span class="close-btn" onclick="closeNoDataModal()">&times;</span>

        <h4 style="color:red;">No Records Found</h4>
        <p>No employees matched your search.</p>

        <button class="btn btn-secondary" onclick="closeNoDataModal()">
            OK
        </button>
    </div>
</div>
